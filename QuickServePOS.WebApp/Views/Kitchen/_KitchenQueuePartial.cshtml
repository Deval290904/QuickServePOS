@using QuickServePOS.Models.ViewModel.KOT
@model List<KitchenQueueViewModel>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No active KOT available.
    </div>
}
else
{
    <div class="row">

        @foreach (var kot in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-3">

                <div class="card kitchen-kot-card">

                    <div class="card-header
                                                        d-flex
                                                        justify-content-between">

                        <span class="fw-bold">
                            @kot.KOTNumber
                        </span>

                        <span class="badge bg-warning">
                            @kot.Status
                        </span>

                    </div>

                    <div class="card-body">

                        <p>
                            <strong>Table:</strong>
                            @kot.TableName
                        </p>

                        <p>
                            <strong>Total Items:</strong>
                            @kot.TotalItems
                        </p>

                        <p>
                        <strong>Status:</strong>
                            @kot.Status
                        </p>

                        <p>
                            <strong>Created:</strong>
                            @(kot.GeneratedAt
                                                .ToLocalTime()
                                                .ToString("dd-MM-yyyy hh:mm tt"))
                </p>

                    </div>

                    <div class="card-footer d-flex gap-2 justify-content-between flex-wrap">

                        <button class="btn btn-sm btn-info view-details-btn"
                                data-kot-id="@kot.KOTId">

                            Details
                        </button>

                        @if (kot.Status == "New")
                        {
                            <button class="btn btn-sm btn-warning update-status-btn"
                                    data-kot-id="@kot.KOTId"
                                    data-status="Preparing">

                                Preparing
                            </button>
                        }

                        @if (kot.Status == "Preparing")
                        {
                            <button class="btn btn-sm btn-success update-status-btn"
                                    data-kot-id="@kot.KOTId"
                                    data-status="Ready">

                                Ready
                            </button>
                        }

                    </div>

                </div>

            </div>
        }

    </div>
}