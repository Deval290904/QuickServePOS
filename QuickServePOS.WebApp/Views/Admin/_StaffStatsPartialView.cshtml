@using QuickServePOS.Models.ViewModel
@using QuickServePOS.Models.ViewModel.Authentication
@using QuickServePOS.Models.ViewModel.Profile
@model DashboardStatsViewModel

<div class="row mb-4">

    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">

                <h6 class="text-muted">Total Staff</h6>

                <h2 class="fw-bold">
                    @(Model?.TotalStaff ?? 0)
                </h2>

            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">

                <h6 class="text-muted">Active Staff</h6>

                <h2 class="fw-bold text-success">
                    @(Model?.ActiveStaff ?? 0)
                </h2>

            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">

                <h6 class="text-muted">Deleted Staff</h6>

                <h2 class="fw-bold text-danger">
                    @(Model?.DeletedStaff ?? 0)
                </h2>

            </div>
        </div>
    </div>

</div>
