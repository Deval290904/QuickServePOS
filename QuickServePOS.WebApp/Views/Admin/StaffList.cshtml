@using QuickServePOS.Models.ViewModel
@using QuickServePOS.Models.ViewModel.Profile
@model List<StaffListViewModel>

<div class="container-fluid py-3">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">Staff Management</h2>
            <p class="text-muted mb-0">
                Manage staff accounts, roles and permissions
            </p>
        </div>

        <div class="d-flex gap-2">

            <button class="btn btn-primary px-4 shadow-sm"
                    onclick="OpenModal('/Admin/CreateStaff', 'Add Staff')">
                <i class="fa fa-plus me-2"></i> Add Staff
            </button>

            <button class="btn btn-outline-danger shadow-sm"
                    onclick="loadTrash()">
                <i class="fa fa-trash me-2"></i> Trash
            </button>

            <button class="btn btn-outline-secondary shadow-sm"
                    onclick="loadActive()">
                <i class="fa fa-users me-2"></i> Active
            </button>

        </div>
    </div>

    <!-- STATS -->
    <div id="statsContainer">
        <partial name="_StaffStatsPartialView" model="ViewBag.Stats" />
    </div>

    <!-- STAFF TABLE -->
    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-header bg-white border-0 py-3">
            <div class="d-flex justify-content-between align-items-center">

                <h5 class="mb-0 fw-semibold">
                    Staff List
                </h5>

                <input type="text"
                       class="form-control w-25"
                       placeholder="Search staff..." />
            </div>
        </div>

        <div class="card-body">

            <div class="table-responsive" id="staffTableContainer">
                <partial name="_StaffTablePartialView" model="Model" />
            </div>

        </div>
    </div>

</div>
@section Scripts {

    <script src="~/js/modules/staff.js"></script>

}
