@using QuickServePOS.Models.Entities.Enums
@using QuickServePOS.Models.ViewModel.Table

@model CreateTableViewModel

<form asp-action="Create"
      method="post">

    <div class="row">

        <!-- FLOOR -->

        <div class="col-md-6 mb-3">

            <label asp-for="FloorId"
                   class="form-label fw-semibold">

                Floor

            </label>

            <select asp-for="FloorId"
                    asp-items="Model.Floors"
                    class="form-select">

                <option value="">
                    -- Select Floor --
                </option>

            </select>

            <span asp-validation-for="FloorId"
                  class="text-danger">
            </span>

        </div>


        <!-- TABLE NUMBER -->

        <div class="col-md-6 mb-3">

            <label asp-for="TableNumber"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="TableNumber"
                   class="form-control"
                   placeholder="Enter table number" />

            <span asp-validation-for="TableNumber"
                  class="text-danger">
            </span>

        </div>


        <!-- CAPACITY -->

        <div class="col-md-6 mb-3">

            <label asp-for="Capacity"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="Capacity"
                   class="form-control"
                   placeholder="Enter capacity" />

            <span asp-validation-for="Capacity"
                  class="text-danger">
            </span>

        </div>


        <!-- STATUS -->

        <div class="col-md-6 mb-3">

            <label asp-for="Status"
                   class="form-label fw-semibold">
            </label>

            <select asp-for="Status"
                    class="form-select"
                    asp-items="Html.GetEnumSelectList<TableStatus>()">
            </select>

            <span asp-validation-for="Status"
                  class="text-danger">
            </span>

        </div>

    </div>


    <!-- BUTTONS -->

    <div class="text-end">

        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">

            Cancel

        </button>

        <button type="submit"
                class="btn btn-primary">

            Save Table

        </button>

    </div>

</form>