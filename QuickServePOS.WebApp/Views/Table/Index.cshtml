@using QuickServePOS.Models.ViewModel.Table
@model List<TableViewModel>

@{
    ViewData["Title"] = "Table Management";
}

<div class="card border-0 shadow-sm">

    <div class="card-header bg-white d-flex justify-content-between align-items-center">

        <h4 class="mb-0 fw-bold">
            Restaurant Table Management
        </h4>

        <div class="d-flex gap-2">

            <button class="btn btn-primary"
                    onclick="OpenModal('/Table/Create','Add Table')">

                <i class="fa fa-plus me-1"></i>
                Add Table
            </button>


            <button class="btn btn-outline-dark"
                    onclick="loadTrashTables()">

                <i class="fa fa-trash me-1"></i>
                Trash

            </button>

            <button class="btn btn-outline-secondary"
                    onclick="loadActiveTables()">

                <i class="fa fa-rotate-left me-1"></i>
                Active

            </button>



        </div>

    </div>

    <div class="card-body">

        <div class="table-responsive" id="tableTableContainer">

            <partial name="_TableListPartialView" model="Model" />

        </div>

    </div>

</div>
@section Scripts {

    <script src="~/js/modules/table.js"></script>
}