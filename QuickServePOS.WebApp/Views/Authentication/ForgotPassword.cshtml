@model QuickServePOS.Models.ViewModel.ForgotPasswordViewModel

@{
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
    ViewData["Title"] = "Forgot Password";
}

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>Forgot Password</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="~/css/site.css"
          rel="stylesheet" />

</head>

<body class="bg-light">

    <div class="container">

        <div class="row justify-content-center align-items-center vh-100">

            <div class="col-md-5">

                <div class="card shadow border-0">

                    <div class="card-body p-4">

                        <div class="text-center mb-4">

                            <h2 class="fw-bold">
                                QuickServe POS
                            </h2>

                            <p class="text-muted">
                                Forgot your password?
                            </p>

                        </div>

                        <form asp-action="ForgotPassword"
                              method="post">

                            <div class="mb-3">

                                <label class="form-label">
                                    Email Address
                                </label>

                                <input asp-for="Email"
                                       class="form-control"
                                       placeholder="Enter your email" />

                                <span asp-validation-for="Email"
                                      class="text-danger">
                                </span>

                            </div>

                            <button type="submit"
                                    class="btn btn-primary w-100">

                                Send Reset Link

                            </button>

                        </form>

                        <div class="text-center mt-3">

                            <a asp-action="Login"
                               asp-controller="Authentication"
                               class="text-decoration-none">

                                Back to Login

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>
</html>