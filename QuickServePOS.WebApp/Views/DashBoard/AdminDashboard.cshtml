@using QuickServePOS.Models.ViewModel.Admin
@model DashboardViewModel


<div class="container-fluid">

    <!-- PAGE TITLE -->

    <div class="row mb-4">

        <div class="col-md-12">

            <div class="d-flex justify-content-between align-items-center">

                <div>

                    <h2 class="fw-bold mb-1">
                        QuickServe POS Dashboard
                    </h2>

                    <p class="text-medium-emphasis">
                        Restaurant overview and live statistics
                    </p>

                </div>

                @* <div>

                    <a asp-controller="Order"
                       asp-action="Create"
                       class="btn btn-warning text-white">

                        <i class="cil-cart"></i>
                        New Order

                    </a>

                </div> *@

            </div>

        </div>

    </div>

    <!-- KPI CARDS -->

    <div class="row">

        <!-- TOTAL ORDERS -->

        <div class="col-sm-6 col-xl-3 mb-4">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <div class="text-medium-emphasis small">
                                Total Orders
                            </div>

                            <div class="fs-3 fw-semibold">
                                @(Model?.TotalOrders ?? 0)
                            </div>

                        </div>

                        <div class="bg-primary bg-opacity-10 p-3 rounded">

                            <i class="fa-solid fa-cart-shopping fs-3 text-primary"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- PENDING ORDERS -->

        <div class="col-sm-6 col-xl-3 mb-4">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <div class="text-medium-emphasis small">
                                Pending Orders
                            </div>

                            <div class="fs-3 fw-semibold">
                                @(Model?.PendingOrders ?? 0)
                            </div>

                        </div>

                        <div class="bg-warning bg-opacity-10 p-3 rounded">

                            <i class="fa-solid fa-clock fs-3 text-warning"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- MENU ITEMS -->

        <div class="col-sm-6 col-xl-3 mb-4">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <div class="text-medium-emphasis small">
                                Menu Items
                            </div>

                            <div class="fs-3 fw-semibold">
                                @(Model?.TotalMenuItems ?? 0)
                            </div>

                        </div>

                        <div class="bg-success bg-opacity-10 p-3 rounded">

                            <i class="fa-solid fa-bowl-food fs-3 text-success"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- TABLES -->

        <div class="col-sm-6 col-xl-3 mb-4">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <div class="text-medium-emphasis small">
                                Total Tables
                            </div>

                            <div class="fs-3 fw-semibold">
                                @(Model?.TotalTables ?? 0)
                            </div>

                        </div>

                        <div class="bg-info bg-opacity-10 p-3 rounded">

                            <i class="fa-solid fa-table fs-3 text-info"></i>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- SECOND ROW -->

    <div class="row">

        <!-- REVENUE CARD -->

        <div class="col-lg-6 mb-4">

            <div class="card border-0 shadow-sm h-100">

                <div class="card-header bg-white border-0">

                    <h5 class="mb-0 fw-semibold">
                        Today's Revenue
                    </h5>

                </div>

                <div class="card-body">

                    <h1 class="fw-bold text-success">

                        @(Model?.RunningTables ?? 0)

                    </h1>

                    <p class="text-medium-emphasis">
                        Total completed sales for today
                    </p>

                </div>

            </div>

        </div>

        <!-- RUNNING TABLES -->

        <div class="col-lg-6 mb-4">

            <div class="card border-0 shadow-sm h-100">

                <div class="card-header bg-white border-0">

                    <h5 class="mb-0 fw-semibold">
                        Running Tables
                    </h5>

                </div>

                <div class="card-body">

                    <h1 class="fw-bold text-primary">

                        @(Model?.RunningTables ?? 0)

                    </h1>

                    <p class="text-medium-emphasis">
                        Currently occupied restaurant tables
                    </p>

                </div>

            </div>

        </div>

    </div>

    <!-- QUICK ACTIONS -->

    <div class="row">

        <div class="col-lg-12">

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-white border-0">

                    <h5 class="mb-0 fw-semibold">

                        Quick Actions

                    </h5>

                </div>

                <div class="card-body">

                    <div class="row g-3">

                        <div class="col-md-3">

                            <a asp-controller="Order"
                               asp-action="Index"
                               class="btn btn-outline-primary w-100 p-3">

                                <i class="fa-solid fa-cart-shopping fs-4 d-block mb-2"></i>

                                Orders

                            </a>

                        </div>

                        <div class="col-md-3">

                            <a asp-controller="MenuItem"
                               asp-action="Index"
                               class="btn btn-outline-success w-100 p-3">

                                <i class="fa-solid fa-utensils fs-4 d-block mb-2"></i>

                                Menu

                            </a>

                        </div>

                        <div class="col-md-3">

                            <a asp-controller="Table"
                               asp-action="Index"
                               class="btn btn-outline-warning w-100 p-3">

                                <i class="fa-solid fa-table-cells-large fs-4 d-block mb-2"></i>

                                Tables

                            </a>

                        </div>

                        <div class="col-md-3">

                            <a asp-controller="Billing"
                               asp-action="Index"
                               class="btn btn-outline-danger w-100 p-3">

                                <i class="fa-solid fa-money-bill-wave fs-4 d-block mb-2"></i>

                                Billing

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>