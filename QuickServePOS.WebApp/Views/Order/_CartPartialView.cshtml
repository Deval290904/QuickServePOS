@using QuickServePOS.Models.ViewModel.Order
@model OrderDetailsViewModel

<div class="card shadow-sm border-0 rounded-4 h-100">

    <!-- HEADER -->

    <div class="card-header bg-white
                d-flex
                justify-content-between
                align-items-center">

        <h5 class="mb-0 fw-bold">

            Cart Items

        </h5>

        <span class="badge bg-dark rounded-pill">

            @Model.Items.Count Item(s)

        </span>

    </div>

    <!-- BODY -->

    <div class="card-body">

        @if (Model.Items != null &&
                Model.Items.Any())
        {
            <div class="table-responsive">

                <table class="table align-middle">

                    <tbody>

                        @foreach (var item in Model.Items)
                        {
                            <tr>

                                <!-- ITEM -->

                                <td>

                                    <strong>
                                        @item.MenuItemName
                                    </strong>

                                    <br />

                                    <small class="text-muted">

                                        ₹ @item.UnitPrice

                                    </small>

                                </td>

                                <!-- QUANTITY -->

                                <td width="140">

                                    <div class="d-flex
                                                        align-items-center
                                                        justify-content-center
                                                        gap-2">

                                        <button class="btn
                                                               btn-outline-danger
                                                               btn-sm">

                                            -

                                        </button>

                                        <span class="fw-bold">

                                            @item.Quantity

                                        </span>

                                        <button class="btn
                                                               btn-outline-success
                                                               btn-sm">

                                            +

                                        </button>

                                    </div>

                                </td>

                                <!-- TOTAL -->

                                <td class="text-end">

                                    <strong>

                                        ₹ @item.TotalPrice

                                    </strong>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

            <!-- SUMMARY -->

            <hr />

            <div class="d-flex
                            justify-content-between
                            mb-2">

                <span class="fw-semibold">

                    Subtotal

                </span>

                <strong>

                    ₹ @Model.Subtotal

                </strong>

            </div>

            <div class="d-flex
                            justify-content-between
                            mb-3">

                <span class="fw-semibold">

                    Total

                </span>

                <strong class="text-success">

                    ₹ @Model.TotalAmount

                </strong>

            </div>

            <!-- CONFIRM BUTTON -->

            <div class="d-grid">

                <button class="btn
                                   btn-success
                                   btn-lg
                                   rounded-pill">

                    Confirm Order

                </button>

            </div>
        }
        else
        {
            <div class="text-center py-5">

                <h6 class="text-muted">

                    No items added

                </h6>

            </div>
        }

    </div>

</div>