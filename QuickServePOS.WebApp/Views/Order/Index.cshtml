@using QuickServePOS.Models.Entities.Enums
@using QuickServePOS.Models.ViewModel.Table
@model List<TableListViewModel>



<link href="~/css/order_CustomCSS.css" rel="stylesheet" />
<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Running Tables</h3>
    </div>

    <div class="row">

        @foreach (var table in Model)
{
    var bgColor = table.Status switch
    {
        TableStatus.Available => "bg-success",
        TableStatus.Occupied => "bg-danger",
        TableStatus.Reserved => "bg-warning",
        TableStatus.Merged => "bg-secondary",
        _ => "bg-light"
    };

    var textColor = table.Status == TableStatus.Reserved
        ? "text-dark"
        : "text-white";

    <div class="col-md-3 mb-4">

        <div class="card @bgColor @textColor shadow-lg border-0 rounded-4 h-100">

            <div class="card-body d-flex flex-column justify-content-between text-center p-4">

                <!-- TABLE NUMBER -->

                <div>

                    <h1 class="fw-bold display-5 mb-2">
                        @table.TableNumber
                    </h1>

                    <h6 class="mb-3">
                        Capacity :
                        @table.Capacity
                    </h6>

                    <span class="badge bg-light text-dark px-3 py-2 fs-6">
                        @table.Status
                    </span>

                </div>

                <!-- BUTTON -->

                <div class="mt-4">

                    @if (table.Status == TableStatus.Available)
                    {
                        <a asp-action="OpenTable"
                           asp-route-tableId="@table.Id"
                           class="btn btn-light text-success fw-bold w-100 rounded-pill">

                            Create Order

                        </a>
                    }

                    else if (table.Status == TableStatus.Occupied)
                    {
                        <a asp-action="OpenTable"
                           asp-route-tableId="@table.Id"
                           class="btn btn-light text-danger fw-bold w-100 rounded-pill">

                            Open Order

                        </a>
                    }

                    else if (table.Status == TableStatus.Reserved)
                    {
                        <button class="btn btn-dark w-100 rounded-pill"
                                disabled>

                            Reserved

                        </button>
                    }

                    else if (table.Status == TableStatus.Merged)
                    {
                        <button class="btn btn-light w-100 rounded-pill"
                                disabled>

                            Merged

                        </button>
                    }

                </div>

            </div>

        </div>

    </div>
}
      

    </div>

</div>