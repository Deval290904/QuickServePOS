@model List<RunningTableViewModel>

@using QuickServePOS.Models.Entities.Enums
@using QuickServePOS.Models.ViewModel.Order

<div class="container-fluid">

    <!-- PAGE HEADER -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="fw-bold mb-0">
                Order Management
            </h3>

            <small class="text-muted">
                Restaurant Table Overview
            </small>
        </div>

    </div>

    <!-- TABLE GRID -->

    <div class="row g-4">

        @foreach (var table in Model)
        {
            string cardClass = table.Status switch
            {
                TableStatus.Available => "table-card-available",
                TableStatus.Occupied => "table-card-occupied",
                TableStatus.Reserved => "table-card-reserved",
               
                _ => "bg-light"
            };

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">

                <div class="card table-card shadow-sm @cardClass">

                    <div class="card-body">

                        <!-- TABLE HEADER -->

                        <div class="d-flex justify-content-between align-items-center">

                            <h4 class="fw-bold mb-0">
                                @table.TableNumber
                            </h4>

                            <span class="badge rounded-pill bg-dark">
                                @table.Status
                            </span>

                        </div>

                        <!-- FLOOR -->

                        <div class="mt-3">

                            <small class="text-muted">
                                Floor
                            </small>

                            <div class="fw-semibold">
                                @table.FloorName
                            </div>

                        </div>

                        <!-- CAPACITY -->

                        <div class="mt-2">

                            <small class="text-muted">
                                Capacity
                            </small>

                            <div class="fw-semibold">
                                @table.Capacity Persons
                            </div>

                        </div>

                        <!-- ACTION -->

                        <div class="mt-4">

                            @if (table.Status == TableStatus.Available)
                            {
                                <a asp-action="OpenTable"
                                   asp-route-tableId="@table.Id"
                                   class="btn btn-success w-100">

                                    Create Order

                                </a>
                            }

                            else if (table.Status == TableStatus.Occupied)
                            {
                                <a asp-action="OpenTable"
                                   asp-route-tableId="@table.Id"
                                   class="btn btn-danger w-100">

                                    Order Details

                                </a>
                            }

                            else if (table.Status == TableStatus.Reserved)
                            {
                                <button class="btn btn-warning w-100"
                                        disabled>

                                    Reserved

                                </button>
                            }

                            

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

