@model QuickServePOS.Models.ViewModel.Order.OrderDetailsViewModel

<div class="card shadow-sm border-0 rounded-4 mt-3">

    <div class="card-header bg-white">
        <h5 class="mb-0">
            Summary
        </h5>
    </div>

    <div class="card-body">

        <div class="d-flex justify-content-between mb-2">
            <span>Subtotal</span>
            <strong>₹ @Model.Subtotal</strong>
        </div>

        <div class="d-flex justify-content-between mb-2">
            <span>Tax</span>
            <strong>₹ @Model.TaxAmount</strong>
        </div>

        <div class="d-flex justify-content-between mb-2">
            <span>Discount</span>
            <strong>₹ @Model.DiscountAmount</strong>
        </div>

        <hr />

        <div class="d-flex justify-content-between">

            <h5>Total</h5>

            <h5>
                ₹ @Model.TotalAmount
            </h5>

        </div>

    </div>

</div>