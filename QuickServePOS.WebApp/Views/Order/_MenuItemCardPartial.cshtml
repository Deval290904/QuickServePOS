@using QuickServePOS.Models.ViewModel.Order
@model MenuItemCardViewModel

<div class="col-6 col-md-4 col-lg-3 col-xl-2 menu-item-card"
     data-category="@Model.CategoryId">

    <div class="card menu-card h-100 border-0 shadow-sm">

        <!-- IMAGE -->

        <img src="https://localhost:7290/@Model.ImageUrl"
             class="menu-image"
             alt="@Model.Name" />

        <!-- BODY -->

        <div class="card-body d-flex flex-column">

            <!-- TITLE -->

            <h6 class="menu-title text-truncate">
                @Model.Name
            </h6>

            <!-- PRICE -->

            <div class="menu-price mb-3">

                ₹ @Model.FullPrice

            </div>

            <!-- FOOTER -->

            <div class="mt-auto">

                <!-- QUANTITY -->

                <div class="qty-wrapper mb-3">

                    <button type="button"
                            class="qty-btn minus-btn">

                        -

                    </button>

                    <input type="text"
                           class="qty-input"
                           value="1"
                           readonly />

                    <button type="button"
                            class="qty-btn plus-btn">

                        +

                    </button>

                </div>

                <!-- ADD BUTTON -->

                <button class="btn add-cart-btn w-100"
                        data-id="@Model.Id"
                        data-name="@Model.Name"
                        data-price="@Model.FullPrice"
                        data-order-id="@Model.OrderId">

                    <i class="fi fi-plus me-1"></i>

                    Add

                </button>

            </div>

        </div>

    </div>

</div>