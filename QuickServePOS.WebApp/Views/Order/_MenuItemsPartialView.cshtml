@using QuickServePOS.Models.ViewModel.Menu
@model List<MenuItemViewModel>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-4">

            <div class="card border-0 shadow-sm rounded-4 menu-item-card h-100">

                <!-- IMAGE -->

                <img src="https://localhost:7290/@item.ImageUrl"
                     class="card-img-top rounded-top-4"
                     style="height:150px; object-fit:cover;" />

                <!-- BODY -->

                <div class="card-body d-flex flex-column">

                    <!-- NAME -->

                    <h6 class="fw-bold mb-2">
                        @item.Name
                    </h6>

                    <!-- PRICE -->

                    <span class="text-success fw-bold mb-3">
                        ₹ @item.FullPrice
                    </span>

                    <!-- QUANTITY -->

                    <div class="d-flex
                                        justify-content-center
                                        align-items-center
                                        gap-2
                                        mb-3">

                        <button type="button"
                                class="btn btn-outline-danger
                                               btn-sm qty-minus-btn">

                            -
                        </button>

                        <input type="text"
                               value="1"
                               class="form-control
                                              text-center
                                              item-qty-input"
                               style="width:60px;" />

                        <button type="button"
                                class="btn btn-outline-success
                                               btn-sm qty-plus-btn">

                            +
                        </button>
                    </div>
                    <!-- ADD BUTTON -->

                    <button type="button" class="btn btn-dark
                                           rounded-pill
                                           add-to-cart-btn"
                            data-menuitemid="@item.Id">

                        Add To Cart

                    </button>

                </div>

            </div>

        </div>
    }

</div>

