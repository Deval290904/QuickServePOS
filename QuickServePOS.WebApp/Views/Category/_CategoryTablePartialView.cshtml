@using QuickServePOS.Models.ViewModel.Menu
@model List<CategoryViewModel>

@{
    bool isTrash = ViewBag.IsTrash ?? false;
}

@if (!Model.Any())
{
    <div class="text-center py-5">

        <img src="https://cdn-icons-png.flaticon.com/512/7486/7486740.png"
             width="120"
             class="mb-3" />

        <h5 class="fw-bold">
            No Categories Found
        </h5>

        <p class="text-muted mb-0">
            Categories will appear here.
        </p>

    </div>
}
else
{
    <table id="categoryTable"
           class="table table-hover align-middle">

        <thead class="table-light">

            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Display Order</th>
                <th>Status</th>
                <th width="150">Actions</th>
            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Name</td>

                    <td>@item.Description</td>

                    <td>@item.DisplayOrder</td>

                    <td>

                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">
                                Active
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Inactive
                            </span>
                        }

                    </td>

                    <td class="text-center">

                        @if (!isTrash)
                        {
                            <!-- ACTIVE -->

                            <button class="btn btn-sm btn-light border shadow-sm me-1"
                                    onclick="OpenModal(
                                                '/Category/Edit/@item.Id',
                                                'Edit Category')">

                                <i class="fa fa-pen text-warning"></i>

                            </button>

                            <button class="btn btn-sm btn-light border shadow-sm"
                                    onclick="DeletehandleAction(
                                                '/Category/Delete',
                                                '@item.Id',
                                                this,
                                                'delete')">

                                <i class="fa fa-trash text-danger"></i>

                            </button>
                        }
                        else
                        {
                            <!-- TRASH -->

                            <button class="btn btn-sm btn-success shadow-sm"
                                    onclick="DeletehandleAction(
                                                '/Category/Restore',
                                                '@item.Id',
                                                this,
                                                'restore')">

                                <i class="fa fa-rotate-left me-1"></i>
                                Restore

                            </button>
                        }

                    </td>

                </tr>
            }

        </tbody>

    </table>
}