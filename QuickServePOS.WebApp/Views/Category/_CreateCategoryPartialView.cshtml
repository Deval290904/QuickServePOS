@using QuickServePOS.Models.ViewModel.Menu
@model CreateCategoryViewModel

<form asp-action="Create"
      method="post">


    <div class="row">

        <!-- NAME -->
        <div class="col-md-12 mb-3">

            <label asp-for="Name"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="Name"
                   class="form-control"
                   placeholder="Enter category name" />

            <span asp-validation-for="Name"
                  class="text-danger"></span>

        </div>

        <!-- DESCRIPTION -->
        <div class="col-md-12 mb-3">

            <label asp-for="Description"
                   class="form-label fw-semibold">
            </label>

            <textarea asp-for="Description"
                      class="form-control"
                      rows="3"
                      placeholder="Enter description">
            </textarea>

            <span asp-validation-for="Description"
                  class="text-danger"></span>

        </div>

        <!-- DISPLAY ORDER -->
        <div class="col-md-6 mb-3">

            <label asp-for="DisplayOrder"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="DisplayOrder"
                   class="form-control" />

            <span asp-validation-for="DisplayOrder"
                  class="text-danger"></span>

        </div>

        <!-- ACTIVE -->
        <div class="col-md-6 mb-3 d-flex align-items-center">

            <div class="form-check mt-4">

                <input asp-for="IsActive"
                       class="form-check-input" />

                <label asp-for="IsActive"
                       class="form-check-label">
                    Active
                </label>

            </div>

        </div>

    </div>

    <div class="text-end">

        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">

            Cancel

        </button>

        <button type="submit"
                class="btn btn-primary">

            Save Category

        </button>

    </div>

</form>