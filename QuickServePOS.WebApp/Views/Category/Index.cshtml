@using QuickServePOS.Models.ViewModel.Menu
@model List<CategoryViewModel>

@{
    ViewData["Title"] = "Category Management";
}

<div class="card border-0 shadow-sm">

    <div class="card-header bg-white d-flex justify-content-between align-items-center">

        <h4 class="mb-0 fw-bold">
            Category Management
        </h4>
      
        <div class="d-flex gap-2">

            <button class="btn btn-primary"
                    onclick="OpenModal('/Category/Create','Add Category')">

                <i class="fa fa-plus me-1"></i>
                Add Category
            </button>


            <button class="btn btn-outline-dark"
                    onclick="loadTrashCategories()">

                <i class="fa fa-trash me-1"></i>
                Trash

            </button>

            <button class="btn btn-outline-secondary"
                    onclick="loadActiveCategories()">

                <i class="fa fa-rotate-left me-1"></i>
                Active

            </button>

            

        </div>

    </div>

    <div class="card-body">

        <div class="table-responsive" id="categoryTableContainer">

            <partial name="_CategoryTablePartialView" model="Model" />

        </div>

    </div>

</div>
@section Scripts {

    <script src="~/js/modules/category.js"></script>
}