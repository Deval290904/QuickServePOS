<!DOCTYPE html>
<html lang="en">
<head>
    <base href="~/">
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">

    <title>QuickServe POS</title>

    <!-- Favicon -->
    <link rel="icon" href="~/assets/favicon/favicon-32x32.png">

    <!-- Vendors styles -->
    <link rel="stylesheet" href="~/vendors/simplebar/css/simplebar.css">
    <link rel="stylesheet" href="~/css/vendors/simplebar.css">

    <!-- CoreUI CSS -->
    <link href="~/css/style.css" rel="stylesheet">
    <link href="~/css/examples.css" rel="stylesheet">

    <!-- Chart -->
    <link href="~/vendors/chartjs/css/coreui-chartjs.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    
    <link href="~/css/custom.css" rel="stylesheet">
    <link href="~/css/DataTable-CustomerCSS.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/order_CustomCSS.css" />
</head>

<body>

    <partial name="_Sidebar" />

    <!-- MAIN WRAPPER -->
    <div class="wrapper d-flex flex-column min-vh-100">

        <!-- HEADER -->
        <header class="header header-sticky p-0 mb-4">
            <div class="container-fluid border-bottom px-4">

                <button class="header-toggler" type="button"
                        onclick="coreui.Sidebar.getInstance(document.querySelector('#sidebar')).toggle()">
                    ☰
                </button>

                <ul class="header-nav ms-auto">
                    <li class="nav-item">
                        <span class="nav-link">Welcome,@User.Identity.Name</span>
                    </li>
                </ul>

            </div>
        </header>

        <!-- MAIN BODY -->
        <div class="body flex-grow-1">
            <div class="container-lg px-4">

                <!-- 🔥 IMPORTANT -->
                @RenderBody()

            </div>
        </div>

        <!-- FOOTER -->
        <footer class="footer px-4">
            <div>© 2026 QuickServe POS</div>
            <div class="ms-auto">
                Powered by CoreUI
            </div>
        </footer>

    </div>

    <!-- Global Reusable Modal -->
    <div class="modal fade" id="AllModals">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">

                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">Modal</h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body" id="modalBody">
                </div>

            </div>
        </div>
    </div>

    <!-- SCRIPTS -->
    <script src="~/vendors/coreui/js/coreui.bundle.min.js"></script>
    <script src="~/vendors/simplebar/js/simplebar.min.js"></script>

    <script src="~/vendors/chart.js/js/chart.umd.js"></script>
    <script src="~/vendors/chartjs/js/coreui-chartjs.js"></script>
    <script src="~/vendors/utils/js/index.js"></script>

    <script src="~/js/main.js"></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>

    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

    <script src="~/js/config.js"></script>
    <script src="~/js/color-modes.js"></script>

    <script src="~/js/common/modal.js"></script>
    <script src="~/js/common/alert.js"></script>
    <script src="~/js/common/delete.js"></script>
    <script src="~/js/common/JqueryDataTable.js"></script>

    <partial name="_Alert" />
    
    @RenderSection("Scripts", required: false)

</body>
</html>




